# Project Settings -> API en Supabase (solo la ANON key: RLS protege los datos)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...

# URL del backend FastAPI (atlos-backend), solo para "Reentrenar modelos" en
# Modelos IA. Requiere que el backend esté corriendo y accesible desde el
# navegador (uvicorn en local sirve para desarrollo; en producción hay que
# desplegarlo en algún servidor). Si se omite, ese botón queda deshabilitado.
VITE_API_URL=http://localhost:8000
